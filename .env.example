# NoWorryCV local config
# Copy to `.env` and fill in your own values.

APP_NAME=NoWorryCV API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
PROMPT_VERSION=v1

# Provider selection: stub | qwen | openai_compatible
LLM_PROVIDER=qwen
LLM_RESPONSE_FORMAT=json_object
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2

# Qwen / DashScope compatible-mode config
QWEN_API_KEY=your_qwen_api_key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Official DashScope env naming is also supported.
# DASHSCOPE_API_KEY=your_qwen_api_key
# DASHSCOPE_MODEL=qwen-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Generic OpenAI-compatible config remains available if you need it.
# LLM_API_KEY=your_api_key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
